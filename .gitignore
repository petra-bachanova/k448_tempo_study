**/.DS_Store
# Ignore BIDS rawdata and derivatives (stored elsewhere, or synced separately)
rawdata/
derivatives/
Electrode_locations/

# Ignore system files
.DS_Store
Thumbs.db

# Ignore Python build/cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.so

# Ignore virtual environments
.venv/
env/
venv/
*.egg-info/

# Ignore Jupyter notebook checkpoints and outputs
.ipynb_checkpoints/
*.nbconvert.ipynb

# Ignore large output files
*.h5
*.edf
*.fif
*.set
*.vhdr
*.eeg
*.bdf
*.tsv.gz
*.nii
*.nii.gz

# Ignore temp files
*.log
*.tmp
*.bak

# Ignore MNE/EEGLAB/FieldTrip cache directories
mne_data/
mne_cache/
scratch/
